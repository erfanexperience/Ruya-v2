# ─── Supabase (required — frontend reads articles from here) ─────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ─── Gemini (required — on-demand card translation) ──────────────────────────
VITE_GEMINI_KEY=your_gemini_key_here

# ─── News API keys (moved to Supabase Edge Function secrets — NOT needed here) ─
# These are now set via: npx supabase secrets set NEWSAPI_KEY=...
# VITE_NEWSAPI_KEY=
# VITE_GNEWS_KEY=
# VITE_THENEWSAPI_KEY=
# VITE_WORLDNEWS_KEY=
