# ─── Supabase (required — frontend reads articles from here) ──────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ─── All AI + News API keys are Supabase Edge Function secrets ────────────────
# Set them via terminal — they never touch the frontend:
#   supabase secrets set ANTHROPIC_KEY=sk-ant-...
#   supabase secrets set NEWSAPI_KEY=...
#   supabase secrets set GNEWS_KEY=...
#   supabase secrets set THENEWSAPI_KEY=...
#   supabase secrets set WORLDNEWS_KEY=...
